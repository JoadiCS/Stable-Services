rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function staff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid))
        ? get(/databases/$(database)/documents/staff/$(request.auth.uid)).data
        : null;
    }
    function isStaff() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/staff/$(request.auth.uid));
    }
    function isTech() {
      return isStaff() && staff().role in ['tech','lead_tech','owner','admin'];
    }
    function isOwnerOrAdmin() {
      return isStaff() && staff().role in ['owner','admin'];
    }
    function isOwner() {
      return isStaff() && staff().role == 'owner';
    }

    match /customers/{customerId} {
      allow read: if isSignedIn()
        && (request.auth.uid == customerId || isStaff());
      allow update: if isSignedIn()
        && (request.auth.uid == customerId || isOwnerOrAdmin());
      allow create, delete: if isOwnerOrAdmin();

      match /privateNotes/{noteId} {
        allow read, write: if isStaff();
      }
    }

    match /serviceRequests/{requestId} {
      allow read: if isSignedIn()
        && (resource.data.customerId == request.auth.uid || isStaff());
      allow create: if isSignedIn()
        && request.resource.data.customerId == request.auth.uid;
      allow update: if isStaff();
      allow delete: if isOwner();
    }

    match /visits/{visitId} {
      allow read: if isSignedIn() && (
        resource.data.customerId == request.auth.uid
        || resource.data.techId == request.auth.uid
        || isStaff()
      );
      allow create: if isOwnerOrAdmin();
      allow update: if isSignedIn() && (
        resource.data.techId == request.auth.uid
        || isOwnerOrAdmin()
      );
      allow delete: if isOwner();
    }

    match /staff/{staffId} {
      allow read: if isStaff();
      // Owner manages the roster directly.
      allow write: if isOwner();
      // First-sign-in self-claim: the tech can create their own /staff/{uid}
      // record only if a matching /staffPending/{email} entry exists. The
      // email on the new staff doc must match their auth token email.
      allow create: if request.auth.uid == staffId
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/staffPending/$(request.auth.token.email))
        && request.resource.data.email == request.auth.token.email;
    }

    match /staffPending/{emailKey} {
      // Staff see the full pending roster. Signed-in users with matching
      // email can read their own pending entry (so the client can claim it
      // on first sign-in).
      allow read: if isStaff()
        || (isSignedIn() && request.auth.token.email == emailKey);
      // Admins create + edit pending invites.
      allow create, update: if isOwnerOrAdmin();
      // Either the admin or the matching tech may delete (the tech deletes
      // their own pending row after the claim succeeds).
      allow delete: if isOwnerOrAdmin()
        || (isSignedIn() && request.auth.token.email == emailKey);
    }

    // Site copy that the marketing site needs to read without an auth user.
    match /config/site {
      allow read: if true;
      allow write: if isOwnerOrAdmin();
    }

    // Other admin-managed config (pricing, checklists, poolRanges) is
    // staff-only readable.
    match /config/{configId} {
      allow read: if isStaff();
      allow write: if isOwnerOrAdmin();
    }

    match /tasks/{id} {
      allow read, create, update, delete: if isStaff();
    }

    match /calendarEvents/{id} {
      allow read, create, update, delete: if isStaff();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}

# ─────────────────────────────────────────────────────────────────────────
# Stable Services — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────────────────

# Zapier "Catch Hook" URL — set this once you create your Zap.
# Get this URL from: Zapier → Zap → Trigger: Webhooks by Zapier → Catch Hook
# Looks like: https://hooks.zapier.com/hooks/catch/12345678/abcdefg/
VITE_ZAPIER_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────
# Stable Services — environment variables
# Copy this file to `.env.local` and fill in real values.
# ─────────────────────────────────────────────────────────────────────────

# Zapier "Catch Hook" URL — set this once you create your Zap.
# Get this URL from: Zapier → Zap → Trigger: Webhooks by Zapier → Catch Hook
# Looks like: https://hooks.zapier.com/hooks/catch/12345678/abcdefg/
VITE_ZAPIER_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────
# Firebase web app config.
# These get filled in by Joshua after the Firebase web app is created in
# Firebase Console (Project Settings → Your apps → Web app → SDK setup).
# Without them, /portal and /admin routes will fail to authenticate.
# ─────────────────────────────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Cloudinary unsigned upload (visit photos).
# Cloud name comes from your Cloudinary dashboard. Upload preset must be
# configured as "unsigned" in Cloudinary Settings → Upload → Upload presets.
# ─────────────────────────────────────────────────────────────────────────
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
